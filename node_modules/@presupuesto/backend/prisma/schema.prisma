generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  name         String
  googleId     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  transacciones Transaccion[]
  categorias    Categoria[]
  ahorros       Ahorro[]
  objetivos     Objetivo[]
  configuracion Configuracion?
}

model Categoria {
  id            Int           @id @default(autoincrement())
  userId        Int?
  nombre        String
  icono         String        @default("💰")
  tipo          String        // 'ingreso' o 'gasto'
  esPersonalizada Boolean     @default(false)
  createdAt     DateTime      @default(now())

  transacciones Transaccion[]
  objetivos     Objetivo[]

  user          User?         @relation(fields: [userId], references: [id])
}

model Transaccion {
  id          Int      @id @default(autoincrement())
  userId      Int
  tipo        String   // 'ingreso' o 'gasto'
  categoriaId Int
  monto       Float
  descripcion String?
  fecha       DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

model Ahorro {
  id             Int      @id @default(autoincrement())
  userId         Int
  nombre         String
  montoActual    Float    @default(0)
  montoObjetivo  Float
  fechaInicio    DateTime @default(now())
  fechaObjetivo  DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])
  historial      HistorialAporte[]
}

model HistorialAporte {
  id          Int      @id @default(autoincrement())
  ahorroId    Int?
  objetivoId  Int?
  monto       Float
  fecha       DateTime @default(now())
  descripcion String?

  ahorro      Ahorro?   @relation(fields: [ahorroId], references: [id])
  objetivo    Objetivo? @relation(fields: [objetivoId], references: [id])
}

model Objetivo {
  id            Int       @id @default(autoincrement())
  userId        Int
  nombre        String
  montoObjetivo Float
  montoActual   Float     @default(0)
  categoriaId   Int?
  fechaLimite   DateTime
  notificaciones Boolean  @default(true)
  completado    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  categoria      Categoria? @relation(fields: [categoriaId], references: [id])
  user           User      @relation(fields: [userId], references: [id])
  historial      HistorialAporte[]
}

model Configuracion {
  id                  Int     @id @default(autoincrement())
  userId              Int     @unique
  limiteGastos        Float   @default(1000)
  notificacionesEmail Boolean @default(true)
  alertas             Boolean @default(true)

  user                User    @relation(fields: [userId], references: [id])
}